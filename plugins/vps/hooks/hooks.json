{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/block-git-commit.py\" 2>/dev/null || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/block-git-commit.py\""
          }
        ]
      }
    ]
  }
}
