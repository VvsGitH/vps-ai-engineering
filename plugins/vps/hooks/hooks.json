{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/block-dangerous-commands.py\" 2>/dev/null || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/block-dangerous-commands.py\""
          },
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/strip-co-authored-by.py\" 2>/dev/null || python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/strip-co-authored-by.py\""
          }
        ]
      }
    ]
  }
}
